.header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.title-no-margin {
  margin-bottom: 0;
}

.upload-btn {
  margin: 0;
  padding: 0 24rpx;
  min-width: 180rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  background: #111827;
  color: #ffffff;
}

.hint {
  margin-bottom: 16rpx;
  color: #2563eb;
  font-size: 24rpx;
}

.toolbar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  background: #f3f4f6;
  font-size: 28rpx;
  box-sizing: border-box;
}

.clear-text {
  color: #2563eb;
  font-size: 26rpx;
}

.doc-item {
  padding: 20rpx 0;
  border-top: 1rpx solid #e5e7eb;
}

.doc-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.doc-title {
  font-size: 30rpx;
  line-height: 1.4;
  word-break: break-all;
}

.status-pill {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
  background: #e5e7eb;
  color: #374151;
}

.status-ready {
  background: #dcfce7;
  color: #166534;
}

.status-parsing {
  background: #fef3c7;
  color: #92400e;
}

.status-failed {
  background: #fee2e2;
  color: #991b1b;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.doc-summary {
  color: #4b5563;
  font-size: 26rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
