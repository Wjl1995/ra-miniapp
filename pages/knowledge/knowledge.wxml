<view class="page">
  <view class="card">
    <view class="title">Documents</view>
    <view wx:if="{{error}}" style="color:#b91c1c; margin-bottom: 16rpx;">{{error}}</view>
    <block wx:for="{{documents}}" wx:key="id">
      <view data-id="{{item.id}}" bindtap="openDetail" style="padding: 16rpx 0; border-top: 1rpx solid #e5e7eb;">
        <view>{{item.title}}</view>
        <view class="muted">{{item.domain}} | {{item.status}}</view>
      </view>
    </block>
    <view wx:if="{{!documents.length}}" class="muted">No documents yet.</view>
  </view>
</view>
