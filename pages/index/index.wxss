.header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.title-no-margin {
  margin-bottom: 0;
}

.doc-item {
  padding: 16rpx 0;
  border-top: 1rpx solid #e5e7eb;
}

.doc-title {
  font-size: 28rpx;
  line-height: 1.4;
  word-break: break-all;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.ghost-action {
  margin-top: 16rpx;
}

.inline-action {
  margin-top: 12rpx;
}
